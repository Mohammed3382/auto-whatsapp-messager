{
  "name": "auto-whatsapp-messager",
  "version": "1.3.0",
  "description": "Send one message to a list of WhatsApp contacts automatically, with human-like delays, via WhatsApp Web (no API). Bilingual desktop app.",
  "main": "main.js",
  "author": "Auto WhatsApp Messager",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "dev": "electron .",
    "icon": "node build/gen-icon.js",
    "dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "express": "^4.21.2",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.26.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.autowa.messager",
    "productName": "Auto WhatsApp Messager",
    "copyright": "Auto WhatsApp Messager",
    "files": [
      "main.js",
      "server.js",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": ".puppeteer-cache/chrome",
        "to": "puppeteer-cache/chrome"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "publisherName": "Auto WhatsApp Messager"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Auto WhatsApp Messager",
      "artifactName": "AutoWhatsAppMessager-Setup-${version}.exe",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
